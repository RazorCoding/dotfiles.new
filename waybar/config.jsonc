// -*- mode: jsonc -*-
{
  "position": "top",
  "mode": "dock",
 "layer": "overlay",
"exclusive": false,
  "spacing": 1,
"on-sigusr1": "hide",
"on-sigusr2": "show",
  "modules-left": [

"hyprland/workspaces"
  ],

  "modules-center": [
  ],

  "modules-right":[
  "idle_inhibitor",
  "custom/sep",
  "backlight",
"custom/sep",  
"pulseaudio",
"custom/sep",
  "custom/battery_health",
"custom/sep",
  "network",
"custom/sep",
  "custom/cava",
"custom/sep",
  "battery",
"custom/sep",
  "clock",
"custom/sep",
  "tray" 
],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
"format": "{name}:{icon}",
"format-icons": {
  "1": "Chat",
  "2": "Browser",
  "3": "Steam",
  "4": "Code",
  "5": "Spotify",
  "6": "Discord",
  "7": "Work1",
  "8": "Work2",
  "9": "Work3",
  "10": "Work4",
  "focused": "ŌŚÅ",
  "urgent": "’ü¬ Alert",
}
  },

  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "’ĆŻ",
      "unlocked": "’é£"
    }
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },

  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": ["", "’ŗÆ"],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },

  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ŌĖ©{songPosition}|{queueLength}ŌĖ® {volume}% ’Ćü",
    "format-disconnected": "Disconnected ’Ćü",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ’Ćü",
    "unknown-tag": "N/A",
    "interval": 5,
    "consume-icons": { "on": "’āä " },
    "random-icons": { "off": "<span color=\"#f53c3c\">’ü┤</span> ", "on": "’ü┤ " },
    "repeat-icons": { "on": "’Ć× " },
    "single-icons": { "on": "’Ć×1 " },
    "state-icons": { "paused": "’üī", "playing": "’üŗ" },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },

  "idle_inhibitor": {
    "format":"{icon}",
    "format-icons": { "activated": "’ü« ", "deactivated": "’Ŗ© " }
  },

  "tray": { "icon-size":27, "spacing": 7 },

  "clock": {
    "format":"{:%a, %d %b %Y %I:%M:%S %p}",
    "interval": 0,
    "tooltip": false
  },


  "temperature": {
  "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
  "format": "’ŗē {temperatureC}┬░C",
  "critical-threshold": 85,
  "interval": 0
},

"custom/cpu": {
  "exec": "~/.config/waybar/scripts/cpu",
  "interval": 4
},


  "battery": {
  "format": "{icon} {capacity}%",
  "format-charging": "’ā¦ {capacity}%",
  "format-plugged": "’ā¦ {capacity}%",
  "format-warning": "’ā¦ {capacity}%",
  "format-critical": "’ā¦ {capacity}%",
  "format-icons": ["’ā¦","’ā¦","’ā¦","’ā¦","’ā¦"],
  "interval": 1,
  "states": {
    "warning": 30,
    "critical": 20
  }
},

  "battery#bat2": { "bat": "BAT2" },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’ā¦ ",
      "performance": "’ā¦ ",
      "balanced": "’ēÄ ",
      "power-saver": "’ü¼ "
    }
  },
"backlight": {
    "device": "amdgpu_bl2",
    "format": "’åģ {percent}%",
    "on-scroll-up": "brightnessctl -d amdgpu_bl2 set +5%",
    "on-scroll-down": "brightnessctl -d amdgpu_bl2 set 5%-"
},
"network": {
  "interface": "wlan0",
  "format-wifi": "’āü",
  "format-disconnected": "’ä¦",
  "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}\nŌåō {bandwidthDownBits} Ōåæ {bandwidthUpBits}"
},
  "custom/cpu": {
    "format": "’ŗø {}",
    "exec": "mpstat 1 1 | awk '/Average:/ {printf(\"%.1f%%\", 100 - $NF)}'",
    "interval": 5
  },
  "custom/hyprsunset": {
    "exec": "~/.config/waybar/scripts/hyprsunset-module.sh",
    "interval": 300,
    "return-type": "json"
},

  "custom/airplane": {
    "exec": "~/.config/waybar/scripts/airplane_status.sh",
    "interval": 1,
    "return-type": "json",
    "tooltip": true
},

  "custom/battery_health": {
    "exec": "~/.config/waybar/scripts/battery_health.sh",
    "interval": 1,
    "return-type": "plain",
    "tooltip": false
  },

  "custom/cava": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/cava.sh",
    "tooltip": false
  },
"pulseaudio": {
    "format": "’Ć© {volume}%",
    "format-muted": "’Ü® Muted",
    "scroll-step": 5
},
  "custom/net": {
    "exec": "/home/Gnana/.config/waybar/scripts/net_graph.sh",
    "return-type": "json",
    "interval": 1
  },
"custom/public_ip": {
    "exec": "~/.config/waybar/scripts/pub_ip.sh",
    "interval": 300,
    "tooltip": false,
    "format": "’é¼ {}"
},
"custom/sep": {
	"format": "/",  // Powerline style arrow (or Ōöé, ŌØ», ŌĆó, etc.)
},
"custom/rss": {
    "exec": "/home/Gnana/.config/waybar/scripts/rss-notify.sh",
    "interval": 300,   // check every 5 minutes
    "format": "­¤ō░"
},
"custom/pacman": {
    "exec": "~/.config/waybar/scripts/pacman_updates.sh",
    "interval": 300,
    "tooltip": true,
    "return-type": "text",
    "format": "{}"
},
"custom/arch": {
    "format": "ŅĪ¦",
    "tooltip": false
}
}
