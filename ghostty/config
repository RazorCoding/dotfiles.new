# -------- GENERAL --------
#theme = "Banana Blueberry"
theme = "Monokai Soda"
#theme = "Abernathy"
#theme = "Catppuccin Macchiato"
background-opacity = 0.95
window-decoration = false
window-padding-x = 10
window-padding-y = 10

#font-feature = -liga, -dlig, -calt
# -------- COLORS --------
background = #1e1e1e
foreground = #d4d4d4


# If you still want Monokai-like accents, you can add these (optional)
selection-background = #49483e
selection-foreground = #f8f8f2

# -------- FONT --------
font-family = "IosevkaSS18"
font-size = 19.5
adjust-cell-width = 0
font-style = regular
font-style-bold = regular
font-style-italic = italic
font-style-bold-italic = bold italic
font-feature = +feat, +liga, +calt 

cursor-color = #ffffff
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
